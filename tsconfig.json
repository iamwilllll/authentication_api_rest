{
    "include": ["src"],
    "exclude": ["node_modules", "dist"],
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",

        "module": "nodenext",
        "moduleResolution": "nodenext",
        "target": "es2022",
        "lib": ["es2022"],

        "types": ["node"],

        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,

        "strict": true,
        "isolatedModules": true,
        "moduleDetection": "force",
        "skipLibCheck": true,

        "baseUrl": "./src",
        "paths": {
            "@/*": ["*"]
        }
    }
}
