{
    "name": "auth_rest_api",
    "version": "1.0.0",
    "description": "This is a REST API for user authentication and authorization, built with Node.js, Express, and MongoDB. It provides endpoints for user registration, login, password reset, and email verification. The API uses JWT for secure authentication and bcrypt for password hashing.",
    "main": "src/index.ts",
    "type": "module",
    "scripts": {
        "lint": "eslint .",
        "lint:deps": "knip",
        "format": "prettier --write .",
        "build": "rimraf dist && tsc && tsc-alias",
        "dev": "tsx  --watch -r tsconfig-paths/register ./src/index.ts",
        "start": "node ./dist/index.js"
    },
    "_moduleAliases": {
        "@": "dist"
    },
    "paths": {
        "@/*": [
            "*"
        ]
    },
    "author": "Wilfryn Viloria Rosario",
    "license": "ISC",
    "packageManager": "pnpm@10.24.0",
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^20.19.37",
        "@types/nodemailer": "^7.0.11",
        "eslint": "^9.39.4",
        "globals": "^17.4.0",
        "jiti": "^2.6.1",
        "knip": "^6.0.6",
        "prettier": "^3.8.1",
        "rimraf": "^6.1.3",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.2"
    },
    "dependencies": {
        "@wilfrynvil/api-documentation": "^3.0.6",
        "bcrypt": "^6.0.0",
        "colors": "^1.4.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-validator": "^7.3.1",
        "jsonwebtoken": "^9.0.3",
        "module-alias": "^2.3.4",
        "mongodb": "^7.1.1",
        "mongoose": "^9.3.3",
        "nodemailer": "^7.0.13",
        "tsc-alias": "^1.8.16",
        "tsconfig-paths": "^4.2.0"
    }
}
